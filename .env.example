    # PostgreSQL connection string (e.g. postgresql://user:pass@host:5432/db)
    DATABASE_URL = "str" 
    # JWT signing secret — keep long, random, and private in production
    JWT_SECRET = "str"
 
    # Signing algorithm; HS256 is the default per the spec
    JWT_ALGORITHM = "HS256"
 
    # Token lifetime in minutes; defaults to 30
    JWT_EXPIRE_MINUTES = 30